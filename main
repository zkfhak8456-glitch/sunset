'양념게장','대게','킹크랩','조개구이','회','물회','매운탕','알탕','동태탕','대구탕',
'코다리조림','고등어구이','삼치구이','갈치조림','고등어조림','장조림','불닭','불닭볶음면','짜글이','순대국',
'돼지국밥','내장탕','해장국','뼈해장국','설렁탕','우거지국','청국장','비지찌개','호박찌개','콩국수',
'열무국수','비빔국수','잔치국수','냉모밀','크림파스타','로제파스타','알리오올리오','봉골레파스타','투움바파스타','라자냐',
'치즈피자','페퍼로니피자','고르곤졸라피자','불고기피자','하와이안피자','치즈버거','베이컨버거','더블버거','새우버거','치킨버거', '탕볶밥', '짜파게티', '다이어트 안하세요?',
'클럽샌드위치','에그샌드위치','BLT샌드위치','프렌치토스트','와플']
@client.event
async def on_ready():
    print(f'{client.user} 로그인 완료!')

@client.event
async def on_message(message):
    if message.author == client.user:
        return

    if message.content.startswith("!메뉴","!추천"):
        menu = random.choice(menus)
        await message.channel.send(menu)

client.run(os.getenv("TOKEN"))
asyncio.get_event_loop().run_forever()
